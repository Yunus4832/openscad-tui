{
  "name": "CustomLibrary",
  "description": "Example Custom Module Library",
  "file": "custom.scad",
  "version": "1.0",
  "modules": [
    {
      "name": "rounded_cube",
      "description": "Cube with rounded edges (custom module)",
      "accepts_children": false,
      "parameters": [
        {
          "name": "size",
          "param_type": "list",
          "default": "[10, 10, 10]",
          "description": "Cube dimensions [x, y, z]"
        },
        {
          "name": "radius",
          "param_type": "float",
          "default": "1",
          "description": "Corner radius"
        }
      ]
    },
    {
      "name": "hollow_cylinder",
      "description": "Hollow cylinder (custom module)",
      "accepts_children": false,
      "parameters": [
        {
          "name": "h",
          "param_type": "float",
          "default": "10",
          "description": "Height"
        },
        {
          "name": "outer_r",
          "param_type": "float",
          "default": "5",
          "description": "Outer radius"
        },
        {
          "name": "inner_r",
          "param_type": "float",
          "default": "3",
          "description": "Inner radius"
        }
      ]
    },
    {
      "name": "gear",
      "description": "Parametric gear (custom module)",
      "accepts_children": false,
      "parameters": [
        {
          "name": "teeth",
          "param_type": "integer",
          "default": "20",
          "description": "Number of teeth"
        },
        {
          "name": "pitch",
          "param_type": "float",
          "default": "5",
          "description": "Tooth pitch"
        },
        {
          "name": "depth",
          "param_type": "float",
          "default": "2",
          "description": "Tooth depth"
        }
      ]
    },
    {
      "name": "bolt_hole",
      "description": "Standard bolt hole pattern (custom module)",
      "accepts_children": false,
      "parameters": [
        {
          "name": "diameter",
          "param_type": "float",
          "default": "3",
          "description": "Hole diameter"
        },
        {
          "name": "depth",
          "param_type": "float",
          "default": "5",
          "description": "Hole depth"
        },
        {
          "name": "count",
          "param_type": "integer",
          "default": "4",
          "description": "Number of holes"
        }
      ]
    }
  ]
}
