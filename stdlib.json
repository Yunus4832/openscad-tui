{
  "name": "StandardLibrary",
  "description": "OpenSCAD Standard Library Definitions",
  "file": "stdlib.scad",
  "version": "1.0",
  "modules": [
    {
      "name": "cube",
      "description": "Creates a cube",
      "accepts_children": false,
      "parameters": [
        {
          "name": "size",
          "param_type": "list",
          "default": "1",
          "description": "Cube dimensions [x, y, z] or single value"
        },
        {
          "name": "center",
          "param_type": "boolean",
          "default": "false",
          "description": "Center the cube at origin"
        }
      ]
    },
    {
      "name": "sphere",
      "description": "Creates a sphere",
      "accepts_children": false,
      "parameters": [
        {
          "name": "r",
          "param_type": "float",
          "default": "1",
          "description": "Radius of the sphere"
        },
        {
          "name": "$fn",
          "param_type": "integer",
          "description": "Number of fragments for rendering quality"
        }
      ]
    },
    {
      "name": "cylinder",
