    },
    {
      "name": "linear_extrude",
      "description": "Extrudes 2D child geometry along the Z axis",
      "accepts_children": true,
      "parameters": [
        {
          "name": "height",
          "param_type": "float",
          "default": "1",
          "description": "Extrusion height"
        },
        {
          "name": "center",
          "param_type": "boolean",
          "default": "false",
          "description": "Center the extrusion on the Z axis"
        },
        {
          "name": "convexity",
          "param_type": "integer",
          "default": "1",
          "description": "Maximum number of front and back faces along a ray"
        },
        {
