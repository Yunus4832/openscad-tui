        {
          "name": "$fn",
          "param_type": "integer",
          "default": "0",
          "description": "Fragment count used to refine a twisted extrusion"
        },
        {
          "name": "$fa",
          "param_type": "float",
          "default": "12",
          "description": "Minimum fragment angle"
        },
        {
          "name": "$fs",
